:8080 {
    # The 'route' block ensures these rules are evaluated in this exact order.
    route {
        # The 'handle' directive proxies requests that match a path,
        # WITHOUT stripping the path. This is the correct directive.
        handle /api/* {
            reverse_proxy backend:8000
        }
        handle /token {
            reverse_proxy backend:8000
        }
        handle /register {
            reverse_proxy backend:8000
        }
        handle /users/me {
            reverse_proxy backend:8000
        }

        # As a final fallback, handle all other requests by sending them to the frontend.
        # This MUST be the last block.
        handle {
            reverse_proxy frontend:8081
        }
    }
}
